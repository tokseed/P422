<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SquareEquation.MainWindow"
        Width="400" Height="300"
        CanResize="False"
        Title="SquareEquation">
    
    <StackPanel Margin="5">
        <StackPanel>
            <TextBox Name="TextBoxA" Width="160" Margin="200,50,200,5" />
            <TextBox Name="TextBoxB" Width="160" Margin="200,5,200, 0" />
            <TextBox Name="TextBoxС" Width="160" Margin="200,5,200, 0" />
            
            <Button Name="Calculate" 
                    Content="   Вычислить" 
                    Width="120" 
                    Height="35"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Bottom" 
                    Margin="0,50,0,20"  
                    Click="SquareRoot_Calculate" />
        </StackPanel>
    </StackPanel>
</Window>
